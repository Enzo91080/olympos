{
  "info": {
    "name": "Olympos Card Clash API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "token2", "value": "" },
    { "key": "deck_id", "value": "" },
    { "key": "deck2_id", "value": "" },
    { "key": "card_id_1", "value": "" },
    { "key": "card_id_2", "value": "" },
    { "key": "player2_id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register Player 1 (zeus)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const j = pm.response.json();",
            "pm.test('Has access_token', () => pm.expect(j.access_token).to.be.a('string'));",
            "pm.collectionVariables.set('token', j.access_token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"zeus\",\n  \"email\": \"zeus@olympos.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Register Player 2 (athena)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('token2', pm.response.json().access_token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"athena\",\n  \"email\": \"athena@olympos.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Register - Duplicate (→ 409)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 409', () => pm.response.to.have.status(409));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"zeus\",\n  \"email\": \"zeus@olympos.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('token', pm.response.json().access_token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"zeus@olympos.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login - Mauvais mot de passe (→ 401)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"zeus@olympos.com\",\n  \"password\": \"mauvais\"\n}" }
          }
        }
      ]
    },
    {
      "name": "2. Player",
      "item": [
        {
          "name": "GET /players/me",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.test('Username = zeus', () => pm.expect(j.username).to.eql('zeus'));",
            "pm.test('EloScore = 1000', () => pm.expect(j.eloScore).to.eql(1000));",
            "pm.test('No passwordHash', () => pm.expect(j.passwordHash).to.be.undefined);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/players/me"
          }
        },
        {
          "name": "GET /players/me (Player 2) — récupère player2_id",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('player2_id', pm.response.json().id);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token2}}" }],
            "url": "{{base_url}}/players/me"
          }
        },
        {
          "name": "PATCH /players/me",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('avatarUrl updated', () => pm.expect(pm.response.json().avatarUrl).to.eql('https://example.com/zeus.png'));"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/players/me",
            "body": { "mode": "raw", "raw": "{\n  \"avatarUrl\": \"https://example.com/zeus.png\"\n}" }
          }
        },
        {
          "name": "GET /players/me - Sans token (→ 401)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ]}}],
          "request": { "method": "GET", "url": "{{base_url}}/players/me" }
        }
      ]
    },
    {
      "name": "3. Cards",
      "item": [
        {
          "name": "GET /cards — 37 cartes",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const cards = pm.response.json();",
            "pm.test('37 cartes', () => pm.expect(cards).to.have.lengthOf(37));",
            "pm.test('Triées par nom', () => pm.expect(cards[0].name).to.be.a('string'));",
            "pm.collectionVariables.set('card_id_1', cards[0].id);",
            "pm.collectionVariables.set('card_id_2', cards[1].id);",
            "console.log('card_id_1 =', cards[0].name, cards[0].id);",
            "console.log('card_id_2 =', cards[1].name, cards[1].id);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/cards"
          }
        },
        {
          "name": "GET /cards/:id",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const c = pm.response.json();",
            "pm.test('Has cardType', () => pm.expect(c.cardType).to.be.oneOf(['creature','spell','artifact']));",
            "pm.test('Has rarity', () => pm.expect(c.rarity).to.be.oneOf(['common','rare','epic','legendary']));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/cards/{{card_id_1}}"
          }
        },
        {
          "name": "GET /cards/:id - Inexistant (→ 404)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 404', () => pm.response.to.have.status(404));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/cards/00000000-0000-0000-0000-000000000000"
          }
        }
      ]
    },
    {
      "name": "4. Decks",
      "item": [
        {
          "name": "GET /decks (vide)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Array vide', () => pm.expect(pm.response.json()).to.be.an('array').with.lengthOf(0));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/decks"
          }
        },
        {
          "name": "POST /decks — Créer Deck 1 (Zeus)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const j = pm.response.json();",
            "pm.test('isValid = false', () => pm.expect(j.isValid).to.eql(false));",
            "pm.collectionVariables.set('deck_id', j.id);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/decks",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Deck Foudre de Zeus\"\n}" }
          }
        },
        {
          "name": "POST /decks — Créer Deck 2 (Athena)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('deck2_id', pm.response.json().id);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token2}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/decks",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Deck Sagesse d'Athena\"\n}" }
          }
        },
        {
          "name": "POST /decks/:id/cards — Ajouter carte (x1)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('quantity = 1', () => pm.expect(pm.response.json().quantity).to.eql(1));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/decks/{{deck_id}}/cards",
            "body": { "mode": "raw", "raw": "{\n  \"cardId\": \"{{card_id_1}}\",\n  \"quantity\": 1\n}" }
          }
        },
        {
          "name": "POST /decks/:id/cards — Ajouter 2ème exemplaire (x1→2)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('quantity = 2', () => pm.expect(pm.response.json().quantity).to.eql(2));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/decks/{{deck_id}}/cards",
            "body": { "mode": "raw", "raw": "{\n  \"cardId\": \"{{card_id_1}}\",\n  \"quantity\": 1\n}" }
          }
        },
        {
          "name": "POST /decks/:id/cards — 3ème exemplaire interdit (→ 400)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('Max 2 copies', () => pm.expect(pm.response.json().message).to.include('2'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/decks/{{deck_id}}/cards",
            "body": { "mode": "raw", "raw": "{\n  \"cardId\": \"{{card_id_1}}\",\n  \"quantity\": 1\n}" }
          }
        },
        {
          "name": "POST /decks/:id/cards — Ajouter 2ème carte",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/decks/{{deck_id}}/cards",
            "body": { "mode": "raw", "raw": "{\n  \"cardId\": \"{{card_id_2}}\",\n  \"quantity\": 1\n}" }
          }
        },
        {
          "name": "GET /decks/:id — Vérifie les cartes",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.test('2 entrées dans deckCards', () => pm.expect(j.deckCards).to.have.lengthOf(2));",
            "pm.test('isValid = false (< 30 cartes)', () => pm.expect(j.isValid).to.eql(false));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/decks/{{deck_id}}"
          }
        },
        {
          "name": "PATCH /decks/:id — Renommer",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Nom mis à jour', () => pm.expect(pm.response.json().name).to.eql('Deck Olympien'));"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/decks/{{deck_id}}",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Deck Olympien\"\n}" }
          }
        },
        {
          "name": "DELETE /decks/:id/cards/:cardId — Retirer carte",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Deleted', () => pm.expect(pm.response.json().deleted).to.be.true);"
          ]}}],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/decks/{{deck_id}}/cards/{{card_id_2}}"
          }
        },
        {
          "name": "GET /decks (liste) — 1 deck visible",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('1 deck', () => pm.expect(pm.response.json()).to.have.lengthOf(1));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/decks"
          }
        },
        {
          "name": "GET /decks/:id — Accès deck d'un autre joueur (→ 403)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 403', () => pm.response.to.have.status(403));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token2}}" }],
            "url": "{{base_url}}/decks/{{deck_id}}"
          }
        },
        {
          "name": "DELETE /decks/:id",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Deleted', () => pm.expect(pm.response.json().deleted).to.be.true);"
          ]}}],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/decks/{{deck_id}}"
          }
        }
      ]
    },
    {
      "name": "5. Matchmaking",
      "item": [
        {
          "name": "POST /matchmaking/join (Player 1)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('matched ou queued', () => pm.expect(pm.response.json()).to.have.property('matched'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/matchmaking/join"
          }
        },
        {
          "name": "POST /matchmaking/join — Déjà en file (→ 409)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 409', () => pm.response.to.have.status(409));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/matchmaking/join"
          }
        },
        {
          "name": "POST /matchmaking/join (Player 2 — doit matcher)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const j = pm.response.json();",
            "pm.test('matched = true', () => pm.expect(j.matched).to.be.true);",
            "pm.test('opponentId présent', () => pm.expect(j.opponentId).to.be.a('string'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token2}}" }],
            "url": "{{base_url}}/matchmaking/join"
          }
        },
        {
          "name": "DELETE /matchmaking/leave — Plus en file (→ 404)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 404', () => pm.response.to.have.status(404));"
          ]}}],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/matchmaking/leave"
          }
        }
      ]
    },
    {
      "name": "6. Games",
      "item": [
        {
          "name": "GET /games/history — Vide",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Array', () => pm.expect(pm.response.json()).to.be.an('array'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/games/history"
          }
        },
        {
          "name": "GET /games/:id — Inexistant (→ 404)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 404', () => pm.response.to.have.status(404));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/games/00000000-0000-0000-0000-000000000000"
          }
        }
      ]
    }
  ]
}
