# ── Base de données (PostgreSQL) ──────────────────────────────────
# Correspond aux identifiants du docker-compose.yml à la racine.
# Si tu utilises ton propre PostgreSQL, adapte user/password/host.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/olympos"

# ── Redis (état des parties en cours) ─────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ────────────────────────────────────────────────────────────
# Générer une vraie valeur : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="changer_en_production"
JWT_EXPIRES_IN="7d"

# ── Serveur ────────────────────────────────────────────────────────
PORT=3000

# ── Email — réinitialisation de mot de passe (OPTIONNEL) ──────────
# Sans ces valeurs, le lien de réinitialisation s'affiche dans la
# console du backend au lieu d'être envoyé par mail.
# Pour Gmail : créer un "mot de passe d'application" (pas le mot de
# passe du compte) : https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@gmail.com
SMTP_PASS=votre_app_password
SMTP_FROM=votre@gmail.com

# URL du front, utilisée dans les liens des emails
FRONTEND_URL=http://localhost:5173

# ── Oracle IA (OPTIONNEL) ──────────────────────────────────────────
# Pas de variable à définir : le backend appelle Ollama sur son URL
# par défaut (http://localhost:11434). Il faut juste avoir lancé :
#   ollama pull gemma3:1b
# Sans Ollama, la route /oracle/ask renvoie une 503 explicite,
# le reste du jeu fonctionne normalement.
